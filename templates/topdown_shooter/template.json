{
  "id": "topdown_shooter",
  "name": "Top-Down Shooter",
  "description": "Action-packed top-down shooter with WASD movement and mouse aiming.",
  "version": "1.0.0",
  "godot_version": "4.2+",
  "author": "Makabaka Engine",
  "license": "MIT",
  "main_scene": "res://scenes/main.tscn",
  "modules_used": [
    "game_manager",
    "input_handler"
  ],
  "customization": {
    "player_speed": {
      "path": "res://scripts/player.gd",
      "property": "speed",
      "type": "float",
      "default": 200.0,
      "description": "Player movement speed"
    },
    "fire_rate": {
      "path": "res://scripts/player.gd",
      "property": "fire_rate",
      "type": "float",
      "default": 0.2,
      "description": "Time between shots (seconds)"
    },
    "bullet_speed": {
      "path": "res://scripts/bullet.gd",
      "property": "speed",
      "type": "float",
      "default": 600.0,
      "description": "Bullet travel speed"
    }
  },
  "input_actions": {
    "move_up": ["KEY_W", "KEY_UP"],
    "move_down": ["KEY_S", "KEY_DOWN"],
    "move_left": ["KEY_A", "KEY_LEFT"],
    "move_right": ["KEY_D", "KEY_RIGHT"],
    "shoot": ["MOUSE_BUTTON_LEFT"]
  }
}
