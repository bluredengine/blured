{
  "id": "platformer_2d",
  "name": "2D Platformer",
  "description": "Classic side-scrolling platformer template with player, enemies, and collectibles.",
  "version": "1.0.0",
  "godot_version": "4.2+",
  "author": "Makabaka Engine",
  "license": "MIT",
  "main_scene": "res://scenes/main.tscn",
  "modules_used": [
    "game_manager",
    "input_handler",
    "player_movement"
  ],
  "customization": {
    "player_speed": {
      "path": "res://scripts/player.gd",
      "property": "speed",
      "type": "float",
      "default": 300.0,
      "description": "Player movement speed"
    },
    "jump_height": {
      "path": "res://scripts/player.gd",
      "property": "jump_velocity",
      "type": "float",
      "default": -400.0,
      "description": "Jump velocity (negative = up)"
    },
    "gravity": {
      "path": "project.godot",
      "setting": "physics/2d/default_gravity",
      "type": "float",
      "default": 980.0,
      "description": "World gravity"
    }
  },
  "input_actions": {
    "move_left": ["KEY_A", "KEY_LEFT"],
    "move_right": ["KEY_D", "KEY_RIGHT"],
    "jump": ["KEY_SPACE", "KEY_W", "KEY_UP"]
  }
}
